# =========================================================
# Environment contract
# =========================================================
# This file documents required configuration.
# Never place real secrets here.
# Copy to .env.local for local development only.
#
# Naming rules:
# - Public client-side vars must be explicitly prefixed in frontend apps.
# - Server-side secrets must never be exposed to browser bundles.
# - Keep values empty here unless a safe non-secret default is useful.
# =========================================================

# ---------------------------------------------------------
# App identity
# ---------------------------------------------------------
APP_NAME=nm-portfolio-api
APP_ENV=local
APP_DEBUG=true
LOG_LEVEL=INFO
API_BASE_URL=http://127.0.0.1:8001
SECRET_KEY=
DATABASE_URL=postgresql+psycopg://postgres:@db:5432/portfolio
# ---------------------------------------------------------
# API / server
# ---------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=8000
API_BASE_URL=http://127.0.0.1:8000

# ---------------------------------------------------------
# CORS
# Comma-separated list, no spaces unless your parser trims them.
# Example:
# CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# ---------------------------------------------------------
CORS_ALLOW_ORIGINS=

# ---------------------------------------------------------
# Database
# Use a dedicated local user/db with minimum privileges.
# Never reuse staging/prod credentials locally.
# ---------------------------------------------------------
DATABASE_URL=sqlite:////app/data/test.db

# ---------------------------------------------------------
# Cache / queues
# ---------------------------------------------------------
REDIS_URL=

# ---------------------------------------------------------
# Auth / crypto
# Generate real values locally; never commit them.
# ---------------------------------------------------------
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ---------------------------------------------------------
# External services
# Leave blank in template.
# ---------------------------------------------------------
SENTRY_DSN=
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
