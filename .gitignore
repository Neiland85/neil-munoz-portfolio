# -----------------------------
# OS / editor noise
# -----------------------------
.DS_Store
Thumbs.db

# -----------------------------
# Python
# -----------------------------
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
.venv/
venv/

# -----------------------------
# Node / frontend
# -----------------------------
node_modules/
.next/
dist/
build/
coverage/

# -----------------------------
# Environment files
# Policy:
# - commit only .env.example
# - never commit real secrets
# -----------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# Optional per-environment files kept out of git by policy
.env.development
.env.test
.env.staging
.env.production

# Allow the template
!.env.example

# -----------------------------
# Logs / dumps
# -----------------------------
*.log
*.out
*.err
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------
# Containers / infra local noise
# -----------------------------
docker-data/
tmp/
