{
  "workbench.startupEditor": "none",
  "workbench.settings.applyToAllProfiles": [],

  "editor.formatOnSave": true,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.rulers": [100, 120],
  "editor.wordWrap": "off",
  "editor.minimap.enabled": false,
  "editor.stickyScroll.enabled": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.renderWhitespace": "boundary",
  "editor.unicodeHighlight.invisibleCharacters": false,
  "editor.inlineSuggest.enabled": false,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit"
  },

  "files.eol": "\n",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.autoSave": "onFocusChange",
  "files.exclude": {
    "**/.git": true,
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
    "**/.mypy_cache": true,
    "**/.venv": true,
    "**/node_modules": true,
    "**/dist": true
  },
  "search.exclude": {
    "**/.git": true,
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
    "**/.mypy_cache": true,
    "**/.venv": true,
    "**/node_modules": true,
    "**/dist": true
  },

  "explorer.compactFolders": false,
  "breadcrumbs.enabled": true,

  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.scrollback": 10000,
  "application.shellEnvironmentResolutionTimeout": 15,

  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": false,
  "git.openRepositoryInParentFolders": "never",
  "diffEditor.ignoreTrimWhitespace": false,
  "diffEditor.codeLens": true,

  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.terminal.activateEnvironment": true,
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": ["tests"],
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.completeFunctionParens": true,
  "python.analysis.inlayHints.variableTypes": true,
  "python.analysis.inlayHints.functionReturnTypes": true,

  "ruff.nativeServer": "on",
  "ruff.organizeImports": true,

  "docker.showStartPage": false,
  "docker.commands.attach": "integratedTerminal",
  "docker.enableTelemetry": false,
  "docker.composeCommand": "docker compose",
  "docker.dockerComposeBuild": true,
  "containers.composeBuild": true,
  "containers.composeDetached": true,
  "containers.contexts.showInStatusBar": false,
  "containers.enableComposeLanguageService": true,
  "containers.images.checkForOutdatedImages": false,
  "containers.networks.showBuiltInNetworks": false,
  "containers.promptForRegistryWhenPushingImages": true,

  "dev.containers.defaultExtensions": [],

  "remote.SSH.useLocalServer": true,
  "remote.SSH.enableDynamicForwarding": true,
  "remote.SSH.lockfilesInTmp": true,
  "remote.SSH.showLoginTerminal": false,

  "files.associations": {
    "*.env": "dotenv",
    ".env.*": "dotenv"
  },
  "[toml]": {
    "editor.formatOnSave": true
  },
  "yaml.format.enable": true,
  "redhat.telemetry.enabled": false,

  "githubPullRequests.pullBranch": "never",

  "cSpell.language": "en,es,es-ES",
  "cSpell.allowCompoundWords": true,

  "security.workspace.trust.enabled": true,
  "security.workspace.trust.untrustedFiles": "open",
  "security.promptForLocalFileProtocolHandling": true,
  "terminal.integrated.allowedLinkSchemes": [
    "file",
    "http",
    "https",
    "mailto",
    "vscode",
    "vscode-insiders",
    "docker-desktop"
  ],

  "telemetry.telemetryLevel": "error",
  "telemetry.editStats.details.enabled": false,
  "extensions.autoCheckUpdates": true,
  "extensions.autoUpdate": false,

  "chat.mcp.discovery.enabled": {
    "cursor-global": false,
    "claude-desktop": false,
    "cursor-workspace": false
  },
  "chat.tools.terminal.autoApprove": {},
  "dev.containers.mountWaylandSocket": false,
  "dev.containers.optimisticallyLaunchDocker": false
}
